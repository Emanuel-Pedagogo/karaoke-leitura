# Supabase: use o pooler em TRANSACTION (porta 6543), não a URL direta em sessão (5432).
# Dashboard → Project Settings → Database → Connection string → "Transaction pooler"
DATABASE_URL="postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Mesma senha, conexão direta (só para prisma db push / migrate — não use no Next.js)
DIRECT_URL="postgresql://postgres.[ref]:[SENHA]@db.[ref].supabase.co:5432/postgres"

AUTH_SECRET="troque-por-uma-chave-longa-e-aleatoria"

# Opcional — transcrição de áudio no servidor (OpenAI Whisper)
# OPENAI_API_KEY="sk-..."

# Obrigatório para análise de voz e geração de textos (Gemini) — https://aistudio.google.com/app/apikey
# Formato: AIza... (não use chaves de outro produto Google)
# GEMINI_API_KEY="AIza..."

# Windows: se aparecer "fetch failed" / certificado SSL, use npm run dev (já inclui --use-system-ca)
# ou: set NODE_OPTIONS=--use-system-ca  (PowerShell: $env:NODE_OPTIONS="--use-system-ca")
