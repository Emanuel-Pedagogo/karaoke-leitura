DATABASE_URL="file:./dev.db"
AUTH_SECRET="troque-por-uma-chave-longa-e-aleatoria"

# Opcional — transcrição de áudio no servidor (OpenAI Whisper)
# OPENAI_API_KEY="sk-..."

# Obrigatório para análise de voz e geração de textos (Gemini) — https://aistudio.google.com/app/apikey
# Formato: AIza... (não use chaves de outro produto Google)
# GEMINI_API_KEY="AIza..."

# Windows: se aparecer "fetch failed" / certificado SSL, use npm run dev (já inclui --use-system-ca)
# ou: set NODE_OPTIONS=--use-system-ca  (PowerShell: $env:NODE_OPTIONS="--use-system-ca")
