# URL pública HTTPS do servidor Next.js em produção.
# O app publicado na Play Store não alcança localhost nem IP da rede local.
#
# Configure também no EAS (recomendado):
#   eas secret:create --scope project --name EXPO_PUBLIC_API_URL --value https://sua-escola.example.com
#
EXPO_PUBLIC_API_URL=https://sua-escola.example.com
